{
  "name": "gatelab",
  "version": "0.2.0",
  "private": true,
  "license": "MIT",
  "type": "module",
  "description": "GateLab — browser-based gating app for flow & mass cytometry (FCS in/out, Gating-ML 2.0). A TypeScript reimplementation reusing GateLabR's D3 engine.",
